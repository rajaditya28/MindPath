# Google Cloud Project
GOOGLE_CLOUD_PROJECT_ID=learning-companion-494405

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Client (public - safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=learning-companion-494405.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=learning-companion-494405
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=learning-companion-494405.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin (server-side only)
FIREBASE_ADMIN_CLIENT_EMAIL=your_service_account_email
FIREBASE_ADMIN_PRIVATE_KEY=your_private_key

# Google Cloud APIs
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# YouTube Data API
YOUTUBE_API_KEY=your_youtube_api_key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
